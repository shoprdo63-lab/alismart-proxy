{
  "version": 2,
  "public": false,
  "functions": {
    "api/search.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/affiliate.js": {
      "maxDuration": 10
    },
    "api/translate.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
